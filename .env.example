# Server
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string-in-production
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Email — required for registration verification codes
# Gmail: enable 2-Step Verification → Google Account → Security → App Passwords → generate one
# If omitted, codes are printed to the server console instead (useful for local dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=Chatloop <you@gmail.com>

# Client (prefix with VITE_ so Vite bundles them)
# Leave blank for local dev — Vite proxy handles /api and /socket.io
# Set to your Render service URL for production builds:
#   VITE_API_URL=https://chatloop-server.onrender.com/api
#   VITE_SOCKET_URL=https://chatloop-server.onrender.com
VITE_API_URL=
VITE_SOCKET_URL=
