# Server
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string-in-production
CLIENT_ORIGIN=http://localhost:5173

# Client (prefix with VITE_ so Vite bundles them)
# Leave blank for local dev — Vite proxy handles /api and /socket.io
# Set to your Render service URL for production builds:
#   VITE_API_URL=https://chatloop-server.onrender.com/api
#   VITE_SOCKET_URL=https://chatloop-server.onrender.com
VITE_API_URL=
VITE_SOCKET_URL=
